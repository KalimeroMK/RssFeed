{
    "name": "kalimeromk/rssfeed",
    "description": "Full-Text RSS extraction package for Laravel - converts partial RSS feeds to full content",
    "type": "package",
    "license": "MIT",
    "keywords": [
        "laravel",
        "rss",
        "feed",
        "full-text",
        "readability",
        "content-extraction"
    ],
    "authors": [
        {
            "name": "Zorab Shefot Bogoevski",
            "email": "zbogoevski@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Kalimeromk\\Rssfeed\\": "./src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kalimeromk\\Rssfeed\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kalimeromk\\Rssfeed\\RssfeedServiceProvider"
            ]
        }
    },
    "require": {
        "php": ">=8.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "simplepie/simplepie": "^1.8.0",
        "masterminds/html5": "^2.8",
        "ezyang/htmlpurifier": "^4.17",
        "ext-curl": "*",
        "ext-libxml": "*",
        "ext-dom": "*",
        "ext-mbstring": "*",
        "spatie/laravel-medialibrary": "^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9|^10|^11",
        "phpunit/phpunit": "^11.5.6",
        "rector/rector": "2.0.9",
        "laravel/pint": "dev-main",
        "phpstan/phpstan": "^2.1",
        "larastan/larastan": "^3"
    },
    "minimum-stability": "dev"
}
